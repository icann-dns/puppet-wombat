# Rotate file for wombat::compactor module
#!/bin/sh

DIR=<%= @data %>

# Delete any file that is past <%= @disk_file_aging %> days.

find ${DIR} -mtime +<%= @disk_file_aging %> -type f -exec rm '{}' \; 2>/dev/null

# Delete/Rotate files if disk is past <%= @disk_usage_watermark %>% used, one file at a time.

while [ $( df ${DIR} | tail -1 | awk '{print $5}' | tr -d '%' ) -gt <%= @disk_usage_watermark %> ]; do
    oldest=$( find ${DIR} -type f 2>/dev/null | sort | head -1 )
    if [ ! ${oldest} ]; then
      logger -t wombat::compactor: no files to rotate, exiting
      exit
    fi
    logger -t wombat::compactor: removing ${oldest}
    rm -f ${oldest} 2>/dev/null
done
