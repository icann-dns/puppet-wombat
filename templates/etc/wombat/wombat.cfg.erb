# Managed by Puppet
#
[datastore]
path=<%= @data_path %>
incoming_dir_pattern=<%= @incoming_dir_pattern %>
reload_dir_pattern=<%= @reload_dir_pattern %>
pcap_dir_pattern=<%= @pcap_dir_pattern %>

[postgres]
database=<%= @db_name %>
user=<%= @db_user %>
<% if @db_host -%>
host=<%= @db_host %>
<%- end -%>

[clickhouse]
servers=<%= @clickhouse_servers.join(',') %>
dbdir=<%= @clickhouse_dbdir %>
import-server=<%= @clickhouse_import_server %>
node-shard-default=<%= @clickhouse_node_shard_default %>
user=<%= @clickhouse_user %>

[pcap]
<%- if @pcap_compress -%>
compress=y
compression-level=<%= @compression_level %>
<%- end -%>
pseudo-anonymise=<% if @anonymisation_passphrase %>Y<% else %>N<% end %>

[loggers]
keys=<%= @loggers.keys.join(',') %>

<%- @loggers.each_pair do |logger, config| -%>
[logger_<%= logger %>]
level=<%= config['level'] %>
<%- if config.fetch('qualname', false) -%>
qualname=<%= config['qualname'] %>
<%- end -%>
<%# propogate is set to True by default -%>
<%- unless config.fetch('propagate', true) -%>
propagate=0
<%- end -%>
handlers=<%= config['handlers'] %>

<%- end -%>
[rssac]
grafana-url=<%= @rssac_url %>
outdir=<%= @rssac_outdir %>
server=<%= @rssac_server %>
zone=<%= @rssac_zone %>

<%- if @maxmind_license_key -%>
[geo]
licencekey=<%= @maxmind_license_key %>
<%- end -%>
