# Managed by Puppet
#
apiVersion: 1

datasources:
 - name: Wombat
   type: vertamedia-clickhouse-datasource
   access: proxy
   url: <%= @wombat_cluster_protocol %>://<%= @wombat_cluster_host %>:<%= @wombat_cluster_port %>

   orgId: 1

   # <bool> enable/disable basic auth
   basicAuth: <%= @basic_auth %>
   # <string> basic auth username
<%- if @basic_auth_user -%>
   basicAuthUser: <%= @basic_auth_user %>
<%- else -%>
   basicAuthUser:
<%- end -%>
   # <string> basic auth password
   basicAuthPassword:
   # <bool> enable/disable with credentials headers
   withCredentials: false
   # <bool> mark as default datasource. Max one per org
   isDefault: true
   # <map> fields that will be converted to json and stored in json_data
   jsonData:
      # <bool> enable/disable sending 'add_http_cors_header=1' parameter
      addCorsHeader: false
      # <bool> enable/disable using POST method for sending queries
      usePOST: true
      # <string> default database name
      defaultDatabase: <%= @database %>
