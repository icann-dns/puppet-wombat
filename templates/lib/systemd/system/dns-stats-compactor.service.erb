[Unit]
Description=DNS-STATS recording daemon
Documentation=man:compactor(1)

[Service]
Type=simple
CPUAffinity=<%= @cpuset.join(',') %>
<%- if @lsbdistcodename == 'xenial' -%>
MemoryLimit=<%= @memory_max %>G 
<%- else -%>
MemoryAccounting=true
MemoryHigh=<%= @memory_high %>G
MemoryMax=<%= @memory_max %>G 
<%- end -%>
ExecStart=/usr/bin/compactor
ExecReload=/bin/kill -HUP $MAINPID
Restart=always

[Install]
WantedBy=multi-user.target
